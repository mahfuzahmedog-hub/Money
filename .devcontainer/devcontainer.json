{
  "name": "OpenCode",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "postCreateCommand": "curl -fsSL https://opencode.ai/install | bash",
  "postStartCommand": "bash /workspace/start.sh",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "OpenCode",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  }
}
